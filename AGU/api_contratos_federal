import requests
import pandas as pd
import time
from datetime import datetime

# =========================================================
# CONFIGURAÇÕES
# =========================================================

TOKEN = "ff15c17bdcbffe1a535a835ffa63f813"

URL = "https://api.portaldatransparencia.gov.br/api-de-dados/contratos"


# =========================================================
# HEADERS
# =========================================================

headers = {
    "accept": "application/json",
    "chave-api-dados": TOKEN,
    "user-agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/122.0 Safari/537.36"
    )
}

# =========================================================
# PARÂMETROS DA CONSULTA
# =========================================================

codigo_orgao = "63000"

# importante usar períodos pequenos
data_inicial = "01/01/2024"
data_final = "31/04/2026"

tamanho_pagina = 100

# =========================================================
# LISTA FINAL
# =========================================================

todos_dados = []

pagina = 1

print("Iniciando extração...")

# =========================================================
# LOOP DE PAGINAÇÃO
# =========================================================

while True:

    params = {
        "pagina": pagina,
        "tamanhoPagina": tamanho_pagina,
        "codigoOrgao": codigo_orgao,
        "dataInicial": data_inicial,
        "dataFinal": data_final
    }

    try:

        response = requests.get(
            URL,
            headers=headers,
            params=params,
            timeout=60
        )

        print(f"\nPágina {pagina}")
        print(f"Status: {response.status_code}")

        # =================================================
        # DETECTAR BLOQUEIO / CAPTCHA
        # =================================================

        texto = response.text.lower()

        if "<html" in texto:
            print("🔴 Bloqueio detectado (CAPTCHA / Cloudflare)")
            break

        # =================================================
        # STATUS DIFERENTE DE 200
        # =================================================

        if response.status_code != 200:
            print("Erro na requisição:")
            print(response.text[:1000])
            break

        # =================================================
        # CONVERTER JSON
        # =================================================

        try:
            dados = response.json()
        except Exception as erro_json:
            print("Erro ao converter JSON:")
            print(erro_json)
            break

        # =================================================
        # FIM DOS DADOS
        # =================================================

        if not dados:
            print("\nFim dos dados.")
            break

        # =================================================
        # ADICIONAR DADOS
        # =================================================

        todos_dados.extend(dados)

        print(f"Registros nesta página: {len(dados)}")
        print(f"Total acumulado: {len(todos_dados)}")

        pagina += 1

        # =================================================
        # PAUSA ANTI-BLOQUEIO
        # =================================================

        time.sleep(5)

    except requests.exceptions.Timeout:
        print("Timeout na requisição.")
        break

    except requests.exceptions.ConnectionError:
        print("Erro de conexão.")
        break

    except Exception as erro:
        print("Erro inesperado:")
        print(erro)
        break

# =========================================================
# CRIAR DATAFRAME
# =========================================================

print("\nCriando DataFrame...")

api_contratos = pd.DataFrame(todos_dados)

# =========================================================
# MOSTRAR RESULTADOS
