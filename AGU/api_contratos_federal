========================================================================================
# TRATAMENTO DOS DADOS
========================================================================================

# drop colunas
api_contratos = api_contratos.drop(columns = [
                                'numeroProcesso',
                                'fundamentoLegal',
                                'compra',
                                'situacaoContrato',
                                'modalidadeCompra',
                                'unidadeGestoraCompras'])


# renommear colunas
api_contratos.rename(columns = {
                    'id': 'id_contrato',
                    'numero': 'num_instrumento',
                    'objeto': 'objeto_contrato',
                    'unidadeGestora': 'ug_contrato',
                    'dataAssinatura': 'dt_assinatura_contrato',
                    'dataPublicacaoDOU': 'dt_publicacao_contrato',
                    'dataInicioVigencia': 'dt_inicio_vigencia_contrato',
                    'fornecedor': 'fornecedor_contrato',
                    'dataFimVigencia': 'dt_fim_vigencia_contrato',
                    'valorInicialCompra': 'R$_inicial_contrato',
                    'valorFinalCompra': 'R$_final_contrato' 
                     }, inplace = True)

display(api_contratos.head(2))
api_contratos.info()

# mostrar a quantidade de registros extraidos
print(f"Total de registros extraídos: {len(api_contratos)}")

========================================================================================

# remover espaços desncessários
api_contratos.columns = api_contratos.columns.str.strip()

api_contratos["ug_contrato"] = api_contratos["ug_contrato"].apply(
    lambda x: x.get("codigo") if isinstance(x, dict) else None
)

#tranformar a coluna "ug_contrato" em integer
api_contratos["ug_contrato"] = pd.to_numeric(api_contratos["ug_contrato"], errors="coerce").astype("Int64")

# mostrar apenas os registros pela coluna "ug_contrato" que tenha o valor igual a 110096
api_contratos = api_contratos[api_contratos["ug_contrato"] == 110096]
display(api_contratos.head())

# mudar a coluna "num_instrumento" para string
api_contratos["num_instrumento"] = api_contratos["num_instrumento"].astype(str)
# incluir "/" após os 8 primeiros caracteres da coluna "num_instrumento"
api_contratos["num_instrumento"] = api_contratos["num_instrumento"].str[:5] + "/" + api_contratos["num_instrumento"].str[5:10]

# excluir os 8 primeiros caracteres da coluna "num_instrumento"
api_contratos["objeto_contrato"] = api_contratos["objeto_contrato"].str[8:]

api_contratos["fornecedor_contrato"] = api_contratos["fornecedor_contrato"].apply(
    lambda x: x.get("cnpjFormatado") if isinstance(x, dict) else None
)

# retirar pontos, traços e barras da coluna "fornecedor"
api_contratos["fornecedor_contrato"] = api_contratos["fornecedor_contrato"].str.replace(r"[.\-\/]", "", regex=True)

#tranformar colunas de data para datetime
colunas_data = [
    "dt_assinatura_contrato",
    "dt_publicacao_contrato",
    "dt_inicio_vigencia_contrato",
    "dt_fim_vigencia_contrato"
]

for coluna in colunas_data:

    api_contratos[coluna] = pd.to_datetime(
        api_contratos[coluna],
        errors="coerce"
    )

# preencher somente a data fim
api_contratos["dt_fim_vigencia_contrato"] = (
    api_contratos["dt_fim_vigencia_contrato"]
    .fillna(pd.Timestamp("2026-12-31"))
)

api_contratos.info()
# mostrar a quantidade de registros extraidos
print(f"Total de registros extraídos: {len(api_contratos)}")

