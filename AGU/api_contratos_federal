print("\nQuantidade de linhas:")
print(api_contratos.shape[0])

print("\nQuantidade de colunas:")
print(api_contratos.shape[1])

print("\nColunas encontradas:")
print(api_contratos.columns.tolist())

print("\nPrévia:")
display(api_contratos.head())

